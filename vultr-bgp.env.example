# Copy to vultr-bgp.env and fill in. Do not commit the real file.
#
# Used by scripts/render-bird-conf.sh to render a BIRD 2 config.

# Vultr platform: "vps" (Cloud Compute) or "bare-metal".
VULTR_PLATFORM=vps

# Your ASN (private ASN assigned by Vultr, or your own public ASN).
LOCAL_ASN=64512

# BGP password from the Vultr customer portal.
BGP_PASSWORD=change-me

# router id is normally the instance public IPv4.
ROUTER_ID=203.0.113.10

# Source addresses BIRD uses for outbound BGP. Leave blank to disable
# that address family.
SOURCE_IPV4=203.0.113.10
SOURCE_IPV6=2001:db8::10

# Space-separated prefixes to announce. Leave blank to disable that AF.
# IPv4 typically needs to be at least a /24, IPv6 at least a /48 to be
# accepted by the global table.
ANNOUNCE_IPV4_PREFIXES="198.51.100.0/24"
ANNOUNCE_IPV6_PREFIXES="2001:db8:100::/48"
